autoload -U promptinit
promptinit

# compinit を sheldon 読み込み前に走らせる
# （zsh-better-npm-completion 等が source 中に compdef を呼ぶため）
autoload -Uz compinit
compinit

# sheldon でプラグインを読み込み（設定は ~/.config/sheldon/plugins.toml）
if command -v sheldon &>/dev/null; then
	eval "$(sheldon source)"
fi

# alias設定
[ -f ~/.zsh/alias.zsh ] && source ~/.zsh/alias.zsh

# オプション・カスタマイズ設定
[ -f ~/.zsh/custom.zsh ] && source ~/.zsh/custom.zsh

# OS毎の設定
case "${OSTYPE}" in
darwin*)
	# Mac(Unix)
	[ -f ~/.zsh/osx.zsh ] && source ~/.zsh/osx.zsh
	;;
linux*)
	# Linux
	[ -f ~/.zsh/linux.zsh ] && source ~/.zsh/linux.zsh
	;;
esac

# Go の GOPATH は明示しなくても Go 1.11+ で $HOME/go がデフォルト。
# bin だけ PATH に通す。
if command -v go &>/dev/null; then
	export PATH="$PATH:$HOME/go/bin"
fi

# Load starship
eval "$(starship init zsh)"

# mise で Ruby / Python / Node 等のバージョンマネージャを統合
# (旧 rbenv / pyenv / nvm の役割を一括で代替)
if command -v mise &>/dev/null; then
	eval "$(mise activate zsh)"
fi

# Load direnv
if type direnv >/dev/null 2>&1; then
	eval "$(direnv hook zsh)"
fi

## local固有設定を読み込み
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
